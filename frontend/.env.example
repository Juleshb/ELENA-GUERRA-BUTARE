# Local development — Vite proxies /api to localhost:5001 (see vite.config.js)
# Leave empty unless you want to hit a remote API while developing.
VITE_API_URL=

# Production build example (same domain with Nginx proxy — recommended):
# VITE_API_URL=

# If the API is on a different origin:
# VITE_API_URL=https://cselenaguerra.site
