DATABASE_URL="postgresql://postgres:password@localhost:5432/school_huye?schema=public"
JWT_SECRET="change-this-to-a-long-random-secret"
PORT=5001
# Frontend URL(s) — comma-separated allowed CORS origins
CLIENT_URL="http://localhost:5173,https://www.cselenaguerrahuye.ac.rw,https://cselenaguerrahuye.ac.rw"

# SMTP — required for contact form confirmation & admin email replies
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
SMTP_FROM_NAME="C.S ELENA GUERRA BUTARE"
SMTP_FROM_EMAIL="noreply@example.com"
SCHOOL_EMAIL="info@elenguerra.rw"

# Twilio — SMS messaging (optional)
TWILIO_ENABLED=true
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# SMS sender — E.164 format, e.g. +14155551234
TWILIO_PHONE_NUMBER="+14155551234"
# Optional — SMS alert when a new contact form message arrives
TWILIO_ADMIN_PHONE="+250788000000"

# WhatsApp provider: meta (recommended) or twilio
WHATSAPP_PROVIDER=meta

# Meta WhatsApp Cloud API — https://developers.facebook.com/docs/whatsapp/cloud-api
META_WHATSAPP_ACCESS_TOKEN="your-meta-permanent-access-token"
META_WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id"
# Optional API version (default v22.0)
META_WHATSAPP_API_VERSION="v22.0"

# Twilio WhatsApp — only if WHATSAPP_PROVIDER=twilio
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
